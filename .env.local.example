# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth (required for login — missing NEXTAUTH_SECRET causes "Configuration" errors)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# On Vercel: set NEXTAUTH_URL to your real URL (https://…), same value as the deployment domain.

# Resend
RESEND_API_KEY=re_your_key_here

# Contact
DISPATCH_EMAIL=dispatch@rudowtransportation.net
COMPANY_PHONE=7708861016

# Site
NEXT_PUBLIC_SITE_URL=https://rudowtransportation.net
NEXT_PUBLIC_PHONE=7708861016
NEXT_PUBLIC_ADDRESS=5382 Winder Hwy, Flowery Branch, GA 30517
